// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// BOM 主数据表
// ============================================
model BOMHeader {
  id            String    @id @default(uuid())
  bomCode      String    @unique
  bomName      String
  bomType      String    @default("MBOM")
  sourceType   String?
  sourceRef    String?
  productModel String?
  version      String    @default("A/1")
  status       String    @default("Draft")
  ebomSourceId String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  releasedBy   String?
  releasedAt   DateTime?

  nodes        MBOMNode[]
  versionLogs  BOMVersionLog[]
  ebomLogs     EBOMToMBOMLog[]  @relation("SourceEBOM")

  @@index([bomCode])
  @@index([status])
}

// ============================================
// BOM 节点表
// ============================================
model MBOMNode {
  id            String    @id @default(uuid())
  bomId         String
  materialId    String?
  
  parentNodeId  String?
  level         Int       @default(0)
  nodeSequence  Int       @default(0)
  
  materialCode  String?
  materialName  String?
  spec         String?
  materialType  String?
  qty           Float    @default(1)
  unit          String    @default("EA")
  isKeyPart     Boolean  @default(false)
  
  processSpecId String?
  version       String    @default("A/1")
  status        String    @default("Active")
  
  creator       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bom           BOMHeader @relation(fields: [bomId], references: [id], onDelete: Cascade)
  material      Material? @relation(fields: [materialId], references: [id])
  parent        MBOMNode?  @relation("NodeHierarchy", fields: [parentNodeId], references: [id], onDelete: SetNull)
  children      MBOMNode[] @relation("NodeHierarchy")
  specRels      NodeSpecRel[]

  @@index([bomId])
  @@index([parentNodeId])
  @@index([level])
  @@index([materialCode])
}

// ============================================
// 物料主数据表
// ============================================
model Material {
  id            String    @id @default(uuid())
  materialCode  String    @unique
  materialName  String
  spec         String?
  materialType  String?
  unit         String    @default("EA")
  supplierId   String?
  isStandard   Boolean  @default(false)
  isKey        Boolean  @default(false)
  sourceSystem String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  nodes        MBOMNode[]

  @@index([materialCode])
  @@index([materialName])
}

// ============================================
// 工艺规程主数据表
// ============================================
model ProcessSpec {
  id            String    @id @default(uuid())
  specCode      String    @unique
  specName      String
  specType      String
  materialCode  String?
  version       String    @default("v1.0")
  status        String    @default("Draft")
  effectiveDate DateTime?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  operations    ProcessOperation[]
  nodeRels      NodeSpecRel[]

  @@index([specCode])
  @@index([status])
}

// ============================================
// 工序明细表
// ============================================
model ProcessOperation {
  id            String    @id @default(uuid())
  specId        String
  operationNo   Int
  operationName String
  workCenter    String?
  standardHours Float?
  setupHours    Float?
  equipment     String?
  operationDesc String?
  qualityRequire String?
  isCritical    Boolean  @default(false)
  
  spec          ProcessSpec @relation(fields: [specId], references: [id], onDelete: Cascade)
  nodeRels      NodeSpecRel[]

  @@index([specId])
  @@index([operationNo])
}

// ============================================
// MBOM节点-工艺规程关联表
// ============================================
model NodeSpecRel {
  id          String    @id @default(uuid())
  nodeId      String
  specId      String
  operationId String?
  assocType  String    @default("Primary")
  assocDate  DateTime  @default(now())
  assocBy     String?

  node        MBOMNode        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  spec        ProcessSpec     @relation(fields: [specId], references: [id], onDelete: Cascade)
  operation   ProcessOperation? @relation(fields: [operationId], references: [id])

  @@unique([nodeId, specId, operationId])
  @@index([nodeId])
  @@index([specId])
}

// ============================================
// BOM 版本变更日志表
// ============================================
model BOMVersionLog {
  id            String    @id @default(uuid())
  bomId         String
  nodeId        String?
  versionFrom   String?
  versionTo     String?
  changeType    String
  changeDesc    String?
  changeReason  String?
  changedBy     String?
  changedAt     DateTime  @default(now())
  ecrNo         String?

  bom           BOMHeader @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@index([bomId])
  @@index([changedAt])
}

// ============================================
// EBOM→MBOM 转换日志表
// ============================================
model EBOMToMBOMLog {
  id              String    @id @default(uuid())
  ebomId          String?
  mbomId          String?
  sourceBomCode   String?
  targetBomCode   String?
  mappingTemplateId String?
  conversionStatus String
  convertedBy     String?
  convertedAt     DateTime  @default(now())
  itemsConverted Int       @default(0)
  itemsFailed     Int       @default(0)
  errorDetail     String?

  sourceBom       BOMHeader? @relation("SourceEBOM", fields: [ebomId], references: [id])

  @@index([conversionStatus])
  @@index([convertedAt])
}

// ============================================
// 校验规则表
// ============================================
model CheckRule {
  id            String    @id @default(uuid())
  ruleCode      String    @unique
  ruleName      String
  ruleType      String
  targetField   String?
  conditionExpr String?
  errorMsg      String
  severity      String    @default("Error")
  isActive      Boolean  @default(true)
  priority      Int       @default(0)
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([ruleCode])
  @@index([isActive])
}

// ============================================
// 导入模板配置表
// ============================================
model ImportTemplate {
  id            String    @id @default(uuid())
  templateName  String
  sourceType    String
  fieldMappings String
  isDefault     Boolean  @default(false)
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([sourceType])
}

// ============================================
// 上传文件记录表
// ============================================
model UploadedFile {
  id            String    @id @default(uuid())
  fileName      String
  filePath      String
  fileSize      Int
  mimeType      String
  sourceType    String?
  parseStatus   String    @default("Pending")
  parsedData    String?
  createdAt     DateTime  @default(now())

  @@index([parseStatus])
}

// ============================================
// 变更通知表
// ============================================
model ChangeNotification {
  id            String    @id @default(uuid())
  type          String
  specId        String
  specCode      String?
  changeType    String
  changeDesc    String?
  affectedNodes String?
  isRead        Boolean  @default(false)
  createdAt     DateTime  @default(now())
  readAt        DateTime?

  @@index([isRead])
  @@index([createdAt])
}
